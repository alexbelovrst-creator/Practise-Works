Дан список размера N. Обнулить элементы списка, расположенные между его 
минимальным и максимальным элементами (не включая минимальный и 
максимальный элементы).

import random

n = input("Введите размер списка N: ")
while type(n) != int:
    try:
        n = int(n)
        if n < 3:
            print("Для решения нужно минимум 3 элемента!")
            n = "error"
    except ValueError:
        print("Ошибка! Введите целое число.")
        n = input("Введите размер списка N: ")

a = []
for _ in range(n):
    a.append(random.randint(1, 50))

print("Исходный список:", a)

idx_min = a.index(min(a))
idx_max = a.index(max(a))

start_idx = min(idx_min, idx_max)
end_idx = max(idx_min, idx_max)

k = start_idx + 1
while k < end_idx:
    a[k] = 0
    k += 1

print(f"Индекс min: {idx_min}, индекс max: {idx_max}")
print("Результирующий список:")
print(a)
