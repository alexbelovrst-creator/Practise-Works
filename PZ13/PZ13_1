# Из текстового файла (writer.txt) выбрать фамилии писателей и годы жизни,
# а также произведения ими написанные. Посчитать общее количество
# произведений в данном файле.

import re

with open("writer.txt", "r", encoding="utf-8") as f:
    text = f.read()

writers = re.findall(r'^([А-ЯЁ][а-яё]+)\s[А-ЯЁ][а-яё]+\s[А-ЯЁ][а-яё]+\s\((\d{4}-\d{4})\)', text, re.MULTILINE)

works = re.findall(r'«([^»]+)»', text)

print("Фамилии писателей и годы жизни:")
for surname, years in writers:
    print(surname, years)

print()
print("Произведения:")
for work in works:
    print(work)

print()
print("Общее количество произведений:", len(works))

