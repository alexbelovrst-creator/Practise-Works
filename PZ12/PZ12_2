
# В матрице найти сумму отрицательных элементов в первой трети матрицы.

matrix = [
    [-3, 5, 2],
    [4, -1, -8],
    [6, 7, -2],
    [-5, 1, 3],
    [2, -9, 4],
    [0, 8, -7],
]

print("Исходная матрица:")
for row in matrix:
    print(row)

rows = len(matrix)
third = rows // 3

first_third = matrix[:third]
print("Первая треть матрицы:")
for row in first_third:
    print(row)

negative_sum = sum(item for row in first_third for item in row if item < 0)

print("Сумма отрицательных элементов в первой трети матрицы:", negative_sum)

