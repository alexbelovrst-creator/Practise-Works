<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <title>HTML5 - Формы</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 20px 40px;
            background: #fff;
            color: #000;
        }

        h1 {
            font-size: 28px;
            font-weight: bold;
            color: #c0392b;
            margin-bottom: 4px;
        }

        p.hint {
            font-style: italic;
            font-size: 13px;
            margin-bottom: 16px;
        }

        p.hint span {
            color: red;
        }

        fieldset {
            border: 1px solid #999;
            margin-bottom: 16px;
            padding: 10px 16px 16px;
        }

        legend {
            font-variant: small-caps;
            font-weight: bold;
            font-size: 14px;
            padding: 0 4px;
        }

        .field {
            display: flex;
            align-items: flex-start;
            margin-top: 10px;
        }

        .field label {
            width: 160px;
            font-size: 14px;
            padding-top: 3px;
        }

        .field input[type="text"],
        .field input[type="email"],
        .field input[type="number"],
        .field select,
        .field textarea {
            font-size: 13px;
            border: 1px solid #aaa;
            padding: 2px 4px;
        }

        .field input[type="text"],
        .field input[type="email"],
        .field input[type="number"] {
            width: 240px;
            height: 22px;
        }

        .field select {
            width: 250px;
            height: 26px;
        }

        .field textarea {
            width: 240px;
            height: 90px;
            resize: vertical;
        }

        .checkboxes {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 8px 0;
            font-size: 14px;
        }

        .checkboxes label {
            display: flex;
            align-items: center;
            gap: 5px;
        }

        .required {
            color: red;
        }

        button[type="submit"] {
            margin-top: 10px;
            padding: 6px 16px;
            font-size: 13px;
            cursor: pointer;
            background: #f0f0f0;
            border: 1px solid #aaa;
        }
    </style>
</head>
<body>

<h1>Форма заявки на работу в зоопарке</h1>
<p class="hint">Пожалуйста, заполните форму. Обязательные поля помечены <span>*</span></p>

<form action="#" method="post">

    <fieldset>
        <legend>Контактная информация</legend>

        <div class="field">
            <label>Имя <span class="required">*</span></label>
            <input type="text" name="name" required>
        </div>

        <div class="field">
            <label>Телефон</label>
            <input type="text" name="phone">
        </div>

        <div class="field">
            <label>Email <span class="required">*</span></label>
            <input type="email" name="email" required>
        </div>
    </fieldset>

    <fieldset>
        <legend>Персональная информация</legend>

        <div class="field">
            <label>Возраст <span class="required">*</span></label>
            <input type="number" name="age" min="18" max="99" required>
        </div>

        <div class="field">
            <label>Пол</label>
            <select name="gender">
                <option value="female">Женщина</option>
                <option value="male">Мужчина</option>
            </select>
        </div>

        <div class="field">
            <label>Перечислите личные качества</label>
            <textarea name="qualities"></textarea>
        </div>
    </fieldset>

    <fieldset>
        <legend>Выберите ваших любимых животных</legend>
        <div class="checkboxes">
            <label><input type="checkbox" name="animal" value="zebra"> Зебра</label>
            <label><input type="checkbox" name="animal" value="cat"> Кошак</label>
            <label><input type="checkbox" name="animal" value="anaconda"> Анаконда</label>
            <label><input type="checkbox" name="animal" value="human"> Человек</label>
            <label><input type="checkbox" name="animal" value="elephant"> Слон</label>
            <label><input type="checkbox" name="animal" value="antelope"> Антилопа</label>
            <label><input type="checkbox" name="animal" value="pigeon"> Голубь</label>
            <label><input type="checkbox" name="animal" value="crab"> Краб</label>
        </div>
    </fieldset>

    <button type="submit">Отправить информацию</button>

</form>

</body>
</html>

