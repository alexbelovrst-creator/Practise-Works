cities = ['Оттава', 'Москва', 'Пекин', 'Полоцк', 'Версаль', 'Дели', 'Каир']
vowels = 'аеёиоуыэюяАЕЁИОУЫЭЮЯ'

consonants = [
    ch.upper()
    for word in cities
    for ch in word
    if ch.isalpha() and ch not in vowels
]

print("Список городов:", cities)
print("Согласные в верхнем регистре:", consonants)

