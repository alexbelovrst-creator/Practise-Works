Дано целое число A. Проверить истинность высказывания: «Число A является 
нечетным».

a = input("Введите целое число A: ")

while type(a) != int:  
    try:
        a = int(a)
    except ValueError:
        print("Вы ввели не целое число!")
        a = input("Введите целое число A: ")

if a % 2 != 0:
    print(f"Число {a} является нечетным: Истина")
else:
    print(f"Число {a} является нечетным: Ложь")
