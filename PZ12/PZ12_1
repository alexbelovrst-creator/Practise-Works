# В матрице найти минимальный и максимальные элементы.

matrix = [
    [4, -2, 7],
    [1, 9, -5],
    [3, 0, 6],
]

print("Исходная матрица:")
for row in matrix:
    print(row)

elements = [item for row in matrix for item in row]

min_elem = min(elements)
max_elem = max(elements)

print("Минимальный элемент:", min_elem)
print("Максимальный элемент:", max_elem)
