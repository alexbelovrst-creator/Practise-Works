Дано целое число A. Проверить истинность высказывания: «Число A является 
нечетным».
try:
    number = int(input("Введите целое число: "))
    # Проверка: трехзначное (100-999) и нечетное (остаток от деления на 2 равен 1)
    is_odd_three_digit = 100 <= abs(number) <= 999 and number % 2 != 0
    print(f"Число является нечетным трехзначным: {is_odd_three_digit}")
except ValueError:
    print("Ошибка ввода")
