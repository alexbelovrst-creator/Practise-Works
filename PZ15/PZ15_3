import sqlite3

conn = sqlite3.connect('abiturient.db')
cur = conn.cursor()

cur.execute('UPDATE anketa SET specialty = ? WHERE last_name = ?', ('Информатика', 'Иванов'))
cur.execute('UPDATE anketa SET awards = ? WHERE specialty = ?', ('да', 'Экономика'))
cur.execute('UPDATE anketa SET address = ? WHERE reg_num = ?', ('ул. Новая 99', 1))
conn.commit()

print("После обновления:")
cur.execute('SELECT * FROM anketa')
for row in cur.fetchall():
    print(row)

cur.execute('DELETE FROM anketa WHERE awards = ? AND specialty = ?', ('нет', 'Юриспруденция'))
cur.execute('DELETE FROM anketa WHERE reg_num = ?', (10,))
cur.execute("DELETE FROM anketa WHERE birth_date < '2005-06-01'")
conn.commit()

print("\nПосле удаления:")
cur.execute('SELECT * FROM anketa')
for row in cur.fetchall():
    print(row)

conn.close()


