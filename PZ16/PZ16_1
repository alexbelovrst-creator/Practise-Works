# Создайте класс «Студент», который имеет атрибуты имя, фамилия и оценки.
# Добавьте методы для вычисления среднего балла и определения,
# является ли студент отличником.

class Student:
    def __init__(self, name, surname, grades):
        self.name = name
        self.surname = surname
        self.grades = grades

    def average_grade(self):
        return sum(self.grades) / len(self.grades)

    def is_excellent(self):
        return all(grade == 5 for grade in self.grades)


student1 = Student("Иван", "Иванов", [5, 4, 5, 5, 5])
student2 = Student("Анна", "Петрова", [5, 5, 5, 5, 5])

print(student1.surname, student1.name)
print("Средний балл:", student1.average_grade())
print("Отличник:", student1.is_excellent())

print()

print(student2.surname, student2.name)
print("Средний балл:", student2.average_grade())
print("Отличник:", student2.is_excellent())
