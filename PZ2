Известно, что X кг шоколадных конфет стоит A рублей, а Y кг ирисок 
стоит B рублей. Определить, сколько стоит 1 кг шоколадных конфет, 1 кг ирисок, а также 
во сколько раз шоколадные конфеты дороже ирисок
try:
    k = int(input("Введите день года K (1-365): "))
    if 1 <= k <= 365:        
       day_of_week = (k - 1 + 1) % 7
        if day_of_week == 0:
            day_of_week = 7
        print(f"Номер дня недели для {k}-го дня: {day_of_week}")
    else:
        print("Число должно быть в диапазоне 1-365")
except ValueError:
    print("Ошибка: введите целое число")
