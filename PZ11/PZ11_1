# Организовать и вывести последовательность А из n чисел (n - четное).
# Из последовательности А получить две последовательности В и С:
# в последовательности В – первая половина элементов А, в С – вторая половина элементов А.
# Найти произведение соответствующих элементов последовательностей В и С.
# Найти среднее арифметическое полученной последовательности.

import random

n = int(input("Введите четное число n: "))
while n % 2 != 0:
    print("Число должно быть четным!")
    n = int(input("Введите четное число n: "))

A = [random.randint(-20, 20) for i in range(n)]
print("Последовательность A:", A)

half = n // 2
B = A[:half]
C = A[half:]

print("Последовательность B:", B)
print("Последовательность C:", C)

D = [B[i] * C[i] for i in range(half)]
print("Последовательность D (произведения B и C):", D)

sr_arifm = sum(D) / len(D)
print("Среднее арифметическое D =", sr_arifm)
