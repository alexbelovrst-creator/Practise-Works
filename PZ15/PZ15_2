import sqlite3

conn = sqlite3.connect('abiturient.db')
cur = conn.cursor()

cur.execute('SELECT * FROM anketa WHERE specialty = ?', ('Программирование',))
print("По специальности 'Программирование':")
for row in cur.fetchall():
    print(row)

cur.execute('SELECT * FROM anketa WHERE awards = ?', ('да',))
print("\nС наградами:")
for row in cur.fetchall():
    print(row)

cur.execute('SELECT * FROM anketa WHERE last_name LIKE ?', ('И%',))
print("\nФамилия на 'И':")
for row in cur.fetchall():
    print(row)

conn.close()

