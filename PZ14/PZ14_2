# Разработать программу с применением пакета tkinter, взяв в качестве условия
# одну любую задачу из ПЗ №№1-9 (простой калькулятор для сложения, вычитания,
# умножения и деления двух чисел).

import tkinter as tk
from tkinter import messagebox

window = tk.Tk()
window.title("Калькулятор")
window.geometry("300x200")

tk.Label(window, text="Число 1:").grid(row=0, column=0, padx=10, pady=10)
entry1 = tk.Entry(window)
entry1.grid(row=0, column=1, padx=10, pady=10)

tk.Label(window, text="Число 2:").grid(row=1, column=0, padx=10, pady=10)
entry2 = tk.Entry(window)
entry2.grid(row=1, column=1, padx=10, pady=10)

label_result = tk.Label(window, text="Результат: ")
label_result.grid(row=2, column=0, columnspan=2, pady=10)


def calculate(operation):
    try:
        a = float(entry1.get())
        b = float(entry2.get())
        if operation == "+":
            result = a + b
        elif operation == "-":
            result = a - b
        elif operation == "*":
            result = a * b
        elif operation == "/":
            result = a / b
        label_result.config(text="Результат: " + str(result))
    except ValueError:
        messagebox.showerror("Ошибка", "Введите числа корректно")
    except ZeroDivisionError:
        messagebox.showerror("Ошибка", "Деление на ноль")


frame_buttons = tk.Frame(window)
frame_buttons.grid(row=3, column=0, columnspan=2)

tk.Button(frame_buttons, text="+", width=5, command=lambda: calculate("+")).grid(row=0, column=0)
tk.Button(frame_buttons, text="-", width=5, command=lambda: calculate("-")).grid(row=0, column=1)
tk.Button(frame_buttons, text="*", width=5, command=lambda: calculate("*")).grid(row=0, column=2)
tk.Button(frame_buttons, text="/", width=5, command=lambda: calculate("/")).grid(row=0, column=3)

window.mainloop()

